{
  "name": "kisan-katta-backend",
  "version": "1.0.0",
  "description": "Kisan Katta backend API server",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "backfill:application-numbers": "ts-node scripts/backfill-application-numbers.ts",
    "migrate:phase-5a3": "ts-node scripts/migrate-phase-5a3-business-flow.ts",
    "payment:reset": "ts-node scripts/payment-reset.ts"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "razorpay": "^2.9.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^7.2.1",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
